# ========================================
# BRAIN HEALTH — Environment Variables Template
# Copy this to .env.local and fill in your values
# ========================================

# --- FIREBASE (Authentication) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (server-side)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com
FIREBASE_ADMIN_PROJECT_ID=your_project_id

# --- SUPABASE (PostgreSQL Database) ---
NEXT_PUBLIC_SUPABASE_URL=https://your_project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql://postgres:password@db.your_project.supabase.co:5432/postgres

# --- AI MODELS ---
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
OPENAI_API_KEY=sk-your_openai_key_for_whisper

# --- OPENROUTER (Free models for testing) ---
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# Other free models: meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-chat-v3-0324:free

# --- PYTHON MICROSERVICE (DoWhy Causal Engine) ---
CAUSAL_ENGINE_URL=http://localhost:8000
# In production: https://your-causal-service.railway.app

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: https://brain-health.vercel.app

# --- DEPLOYMENT ---
NODE_ENV=development
# Set to 'production' for production builds
